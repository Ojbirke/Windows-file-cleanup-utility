<Window x:Class="StoreFiler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StoreFiler"
        Title="Store Filer — finn og frigjør plass" Height="720" Width="1120"
        WindowStartupLocation="CenterScreen" Background="White" Icon="icon.ico">

    <Window.Resources>
        <local:SizeConverter x:Key="Size"/>
        <local:HexBrushConverter x:Key="HexBrush"/>
    </Window.Resources>

    <DockPanel>
        <!-- Verktøylinje øverst -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Mappe:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtleText}"/>
                <TextBox x:Name="PathBox" Width="380" Height="30" VerticalContentAlignment="Center"
                         Padding="6,0" BorderBrush="{StaticResource EdgeBrush}"/>
                <Button Content="Bla gjennom…" Click="OnBrowse" Margin="6,0,12,0"/>

                <TextBlock Text="Minst:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtleText}"/>
                <ComboBox x:Name="MinSizeBox" Width="110" Height="30" VerticalContentAlignment="Center" SelectedIndex="2">
                    <ComboBoxItem Tag="0" Content="Alle"/>
                    <ComboBoxItem Tag="10485760" Content="≥ 10 MB"/>
                    <ComboBoxItem Tag="52428800" Content="≥ 50 MB"/>
                    <ComboBoxItem Tag="104857600" Content="≥ 100 MB"/>
                    <ComboBoxItem Tag="524288000" Content="≥ 500 MB"/>
                    <ComboBoxItem Tag="1073741824" Content="≥ 1 GB"/>
                </ComboBox>

                <Button x:Name="ScanButton" Content="🔍  Skann" Click="OnScan" Margin="12,0,0,0"
                        Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold"/>
                <Button x:Name="StopButton" Content="Stopp" Click="OnStop" IsEnabled="False"/>
                <Button x:Name="AnalyzeButton" Content="🔬  Analyser" Click="OnAnalyze" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Fremdriftsbanner (vises kun mens skanning pågår) -->
        <Border x:Name="ScanBanner" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#EAF3FB" BorderBrush="#CBE0F2" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ScanStats" FontWeight="SemiBold" Foreground="#0B4A82"
                               Text="Skanner…"/>
                </StackPanel>
                <ProgressBar x:Name="Progress" Height="6" IsIndeterminate="True"
                             Foreground="{StaticResource AccentBrush}" Background="#D5E7F6"
                             BorderThickness="0"/>
                <TextBlock x:Name="ScanCurrent" FontSize="11" Foreground="#4A6A88" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis" Text=""/>
            </StackPanel>
        </Border>

        <!-- Statuslinje nederst -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,1,0,0" Padding="10,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink Click="OnOpenWebsite" TextDecorations="{x:Null}" Foreground="{StaticResource SubtleText}">Nettside</Hyperlink>
                    </TextBlock>
                    <TextBlock Text="·" Margin="8,0" Foreground="{StaticResource SubtleText}" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink Click="OnDonate" TextDecorations="{x:Null}" Foreground="#C62828">❤ Støtt utvikleren</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="Klar. Velg en mappe eller disk og trykk Skann."/>
            </DockPanel>
        </Border>

        <!-- Hovedområde: disker til venstre, filliste til høyre -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="340" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Diskliste -->
            <Border Grid.Column="0" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Denne PC-en" FontWeight="SemiBold"
                               Margin="12,12,12,6" Foreground="{StaticResource SubtleText}"/>
                    <ListBox x:Name="DriveList" BorderThickness="0" SelectionChanged="OnDriveSelected"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                    <ProgressBar Value="{Binding UsedPercent}" Maximum="100" Height="6" Margin="0,4"/>
                                    <TextBlock Text="{Binding FreeText}" FontSize="11" Foreground="{StaticResource SubtleText}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Filliste med hurtigfilter øverst -->
            <DockPanel Grid.Column="2">
            <Border DockPanel.Dock="Top" Background="{StaticResource ChromeBrush}"
                    BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1" Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Vis:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtleText}"/>
                    <ComboBox x:Name="FilterBox" Width="190" Height="28" VerticalContentAlignment="Center"
                              SelectedIndex="0" SelectionChanged="OnFilterChanged">
                        <ComboBoxItem Tag="all">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="#BBBBBB" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Alle filer"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="Safe">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="#1B8A3A" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Bare trygge"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="Caution">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="#B8860B" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Vær forsiktig"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="Unsafe">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="#C62828" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Bør ikke slettes"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="Unknown">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="#757575" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Usikre"/>
                            </StackPanel>
                        </ComboBoxItem>
                    </ComboBox>
                    <TextBlock x:Name="CountLabel" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{StaticResource SubtleText}"/>
                </StackPanel>
            </Border>
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Extended" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" BorderThickness="0" RowHeaderWidth="0"
                      HorizontalGridLinesBrush="#F0F0F0" MouseDoubleClick="OnRowDoubleClick"
                      SelectionChanged="OnGridSelectionChanged">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Åpne mappe i Utforsker" Click="OnOpenInExplorer"/>
                        <MenuItem Header="Kopier full sti" Click="OnCopyPath"/>
                        <Separator/>
                        <MenuItem Header="Slett til papirkurv" Click="OnDelete"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="●" SortMemberPath="Analysis.Safety" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="14" Height="14" HorizontalAlignment="Center"
                                         Stroke="#40000000" StrokeThickness="0.5"
                                         Fill="{Binding Analysis.Color, Converter={StaticResource HexBrush}}"
                                         ToolTip="{Binding Analysis.Verdict}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Navn" Binding="{Binding Name}" Width="260"/>
                    <DataGridTextColumn Header="Størrelse" Binding="{Binding Size, Converter={StaticResource Size}}"
                                        SortMemberPath="Size" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="90"/>
                    <DataGridTextColumn Header="Endret" Binding="{Binding Modified, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                    <DataGridTextColumn Header="Mappe" Binding="{Binding Directory}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Detaljpanel: analyse av valgt fil -->
            <Border Grid.Column="4" Background="#FAFAFA" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Analyse" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <!-- Vises når ingenting er valgt -->
                        <TextBlock x:Name="EmptyHint" Foreground="{StaticResource SubtleText}" TextWrapping="Wrap"
                                   Text="Velg en fil i lista (eller klikk «Analyser») for å se hva den er og om det er trygt å slette."/>

                        <!-- Vises når en fil er valgt -->
                        <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                            <!-- Trygghets-merkelapp -->
                            <Border x:Name="VerdictBadge" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="VerdictIcon" FontSize="18" FontWeight="Bold" Foreground="White"
                                               VerticalAlignment="Center" Margin="2,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="VerdictText" FontWeight="Bold" FontSize="15" Foreground="White"/>
                                        <TextBlock x:Name="CategoryText" FontSize="12" Foreground="White" Opacity="0.9"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Navn" FontSize="11" Foreground="{StaticResource SubtleText}"/>
                            <TextBlock x:Name="DName" TextWrapping="Wrap" Margin="0,0,0,10" FontWeight="SemiBold"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Størrelse" FontSize="11" Foreground="{StaticResource SubtleText}"/>
                                    <TextBlock x:Name="DSize" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Program" FontSize="11" Foreground="{StaticResource SubtleText}"/>
                                    <TextBlock x:Name="DApp" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="Vurdering" FontSize="11" Foreground="{StaticResource SubtleText}"/>
                            <TextBlock x:Name="DExplain" TextWrapping="Wrap" Margin="0,2,0,14" LineHeight="19"/>

                            <TextBlock Text="Plassering" FontSize="11" Foreground="{StaticResource SubtleText}"/>
                            <TextBlock x:Name="DPath" TextWrapping="Wrap" Margin="0,2,0,16"
                                       FontSize="11" Foreground="#555"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="📂  Åpne i Utforsker" Click="OnOpenInExplorer"/>
                                <Button Content="🗑  Slett" Click="OnDelete"/>
                            </StackPanel>

                            <TextBlock Margin="0,14,0,0" FontSize="11" Foreground="{StaticResource SubtleText}"
                                       TextWrapping="Wrap"
                                       Text="Vurderingen er en lokal beste-gjetning ut fra plassering og filtype — sjekk alltid selv før du sletter noe du er usikker på."/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
